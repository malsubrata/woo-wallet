{
    "name": "malsubrata/woo-wallet",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "description": "A powerful, extendable WooCommerce wallet system which support payment, partial payment, cashback reward program as well as refund for your WooCommerce store.",
    "homepage": "https://standalonetech.com/",
    "authors": [
        {
            "name": "Subrata Mal",
            "email": "m.subrata1991@gmail.com",
            "homepage": "https://github.com/malsubrata"
        }
    ],
    "keywords": [
        "wordpress",
        "woocommerce-wallet",
        "wallet",
        "wordpress-plugin"
    ],
    "support": {
        "issues": "https://github.com/malsubrata/woo-wallet/issues"
    },
    "require": {
        "php": ">=5.6",
        "composer/installers": "~1.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "wp-phpunit/wp-phpunit": "dev-master"
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}